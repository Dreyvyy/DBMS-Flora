import sys
import pyodbc
from PyQt6.QtWidgets import *

# ================= DATABASE =================
class Database:
    def __init__(self):
        self.conn = pyodbc.connect(
            'DRIVER={ODBC Driver 17 for SQL Server};'
            'SERVER=LIANNEDREY\\SQLEXPRESS;'
            'DATABASE=FLORA;'
            'Trusted_Connection=yes;'
        )
        self.cursor = self.conn.cursor()

    def fetch_records(self, search=""):
        query = """
            SELECT r.Record_Id, c.Crop_name, s.Soil_Type, f.Fertilizer_name,
                   r.Season, r.Amount_Fertilizer_Used_KG
            FROM Records r
            JOIN Crops c ON r.Crop_Id = c.Crop_Id
            JOIN Soil s ON r.Soil_Id = s.Soil_Id
            JOIN Fertilizer f ON r.Fertilizer_Id = f.Fertilizer_Id
        """

        if search:
            query += """
            WHERE c.Crop_name LIKE ? OR s.Soil_Type LIKE ?
            OR f.Fertilizer_name LIKE ? OR r.Season LIKE ?
            """

            self.cursor.execute(query, (f"%{search}%",)*4)
        else:
            self.cursor.execute(query)

        return self.cursor.fetchall()

    def get_crops(self):
        self.cursor.execute("SELECT Crop_Id, Crop_name FROM Crops")
        return self.cursor.fetchall()

    def get_soil(self):
        self.cursor.execute("SELECT Soil_Id, Soil_Type FROM Soil")
        return self.cursor.fetchall()

    def get_fertilizer(self):
        self.cursor.execute("SELECT Fertilizer_Id, Fertilizer_name FROM Fertilizer")
        return self.cursor.fetchall()

    def insert_record(self, crop, soil, fert, season, amount):
        self.cursor.execute("""
            INSERT INTO Records (Crop_Id, Soil_Id, Fertilizer_Id, Season, Amount_Fertilizer_Used_KG)
            VALUES (?, ?, ?, ?, ?)
        """, (crop, soil, fert, season, amount))
        self.conn.commit()

    def update_record(self, rid, crop, soil, fert, season, amount):
        self.cursor.execute("""
            UPDATE Records
            SET Crop_Id=?, Soil_Id=?, Fertilizer_Id=?, Season=?, Amount_Fertilizer_Used_KG=?
            WHERE Record_Id=?
        """, (crop, soil, fert, season, amount, rid))
        self.conn.commit()

    def delete_record(self, rid):
        self.cursor.execute("DELETE FROM Records WHERE Record_Id=?", (rid,))
        self.conn.commit()


# ================= GUI =================
class App(QWidget):
    def __init__(self):
        super().__init__()
        self.db = Database()
        self.setWindowTitle("Crop Management System")

        self.layout = QVBoxLayout()

        # 🔍 SEARCH BAR
        self.search = QLineEdit()
        self.search.setPlaceholderText("Search...")
        self.search.textChanged.connect(self.search_data)
        self.layout.addWidget(self.search)

        # Table
        self.table = QTableWidget()
        self.table.cellClicked.connect(self.load_selected_row)
        self.layout.addWidget(self.table)

        # Inputs
        form = QHBoxLayout()

        self.crop = QComboBox()
        self.soil = QComboBox()
        self.fert = QComboBox()
        self.season = QComboBox()
        self.season.addItems(["Dry", "Rainy"])
        self.amount = QLineEdit()

        form.addWidget(QLabel("Crop"))
        form.addWidget(self.crop)
        form.addWidget(QLabel("Soil"))
        form.addWidget(self.soil)
        form.addWidget(QLabel("Fertilizer"))
        form.addWidget(self.fert)
        form.addWidget(QLabel("Season"))
        form.addWidget(self.season)
        form.addWidget(QLabel("Amount"))
        form.addWidget(self.amount)

        self.layout.addLayout(form)

        # Buttons
        btns = QHBoxLayout()

        add_btn = QPushButton("Add")
        update_btn = QPushButton("Update")
        delete_btn = QPushButton("Delete")
        refresh_btn = QPushButton("Refresh")

        add_btn.clicked.connect(self.add_record)
        update_btn.clicked.connect(self.update_record)
        delete_btn.clicked.connect(self.delete_record)
        refresh_btn.clicked.connect(self.load_data)

        btns.addWidget(add_btn)
        btns.addWidget(update_btn)
        btns.addWidget(delete_btn)
        btns.addWidget(refresh_btn)

        self.layout.addLayout(btns)

        self.setLayout(self.layout)

        self.load_dropdowns()
        self.load_data()

    def load_dropdowns(self):
        self.crop.clear()
        for cid, name in self.db.get_crops():
            self.crop.addItem(name, cid)

        self.soil.clear()
        for sid, name in self.db.get_soil():
            self.soil.addItem(name, sid)

        self.fert.clear()
        for fid, name in self.db.get_fertilizer():
            self.fert.addItem(name, fid)

    def load_data(self):
        data = self.db.fetch_records()
        self.populate_table(data)

    def populate_table(self, data):
        self.table.setRowCount(len(data))
        self.table.setColumnCount(6)
        self.table.setHorizontalHeaderLabels(
            ["ID", "Crop", "Soil", "Fertilizer", "Season", "Amount"]
        )

        for row_idx, row in enumerate(data):
            for col_idx, col in enumerate(row):
                self.table.setItem(row_idx, col_idx, QTableWidgetItem(str(col)))

    # 🔍 SEARCH FUNCTION
    def search_data(self):
        text = self.search.text()
        data = self.db.fetch_records(text)
        self.populate_table(data)

    # 🎯 AUTO-FILL WHEN CLICK ROW
    def load_selected_row(self):
        row = self.table.currentRow()

        crop = self.table.item(row, 1).text()
        soil = self.table.item(row, 2).text()
        fert = self.table.item(row, 3).text()
        season = self.table.item(row, 4).text()
        amount = self.table.item(row, 5).text()

        self.set_combo(self.crop, crop)
        self.set_combo(self.soil, soil)
        self.set_combo(self.fert, fert)
        self.set_combo(self.season, season)
        self.amount.setText(amount)

    def set_combo(self, combo, text):
        index = combo.findText(text)
        if index >= 0:
            combo.setCurrentIndex(index)

    # ✅ VALIDATION
    def validate(self):
        if self.amount.text() == "":
            QMessageBox.warning(self, "Error", "Amount is required")
            return False

        if not self.amount.text().isdigit():
            QMessageBox.warning(self, "Error", "Amount must be a number")
            return False

        return True

    def add_record(self):
        if not self.validate():
            return

        self.db.insert_record(
            self.crop.currentData(),
            self.soil.currentData(),
            self.fert.currentData(),
            self.season.currentText(),
            int(self.amount.text())
        )
        self.load_data()

    def update_record(self):
        row = self.table.currentRow()
        if row == -1:
            return

        if not self.validate():
            return

        rid = int(self.table.item(row, 0).text())

        self.db.update_record(
            rid,
            self.crop.currentData(),
            self.soil.currentData(),
            self.fert.currentData(),
            self.season.currentText(),
            int(self.amount.text())
        )
        self.load_data()

    def delete_record(self):
        row = self.table.currentRow()
        if row == -1:
            return

        rid = int(self.table.item(row, 0).text())

        self.db.delete_record(rid)
        self.load_data()


# ================= RUN =================
app = QApplication(sys.argv)
window = App()
window.show()
sys.exit(app.exec())
