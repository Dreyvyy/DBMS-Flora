    def refresh_all_reports(self):
        self.tabs.clear()
        
        def wrap(table, title=""):
            card = section_card()
            v = QVBoxLayout()
            v.setContentsMargins(0, 0, 0, 0)
            
            if title:
                title_label = QLabel(title)
                title_label.setStyleSheet(f"""
