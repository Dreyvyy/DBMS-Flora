class CenterDelegate(QStyledItemDelegate):
    def initStyleOption(self, option, index):
        super().initStyleOption(option, index)
        option.displayAlignment = Qt.AlignmentFlag.AlignCenter

def page_title(text):
    lbl = QLabel(text)
    lbl.setStyleSheet(f"""
        font-size: 28px; 
        font-weight: 900; 
        color: {ACCENT2}; 
        letter-spacing: 2px; 
        background: transparent;
        margin-bottom: 10px;
    """)
    return lbl

def stat_card(icon, value, label, color=ACCENT2):
    card = QFrame()
    card.setStyleSheet(f"""
        QFrame {{ 
            background-color: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                stop:0 {BG_PANEL}, stop:1 {CREAM});
            border: 1px solid {BORDER}; 
            border-radius: 12px;
        }}
        QFrame:hover {{
            border: 1px solid {ACCENT2};
            transform: scale(1.02);
        }}
    """)
    card.setFixedHeight(110)
    h = QHBoxLayout()
    h.setContentsMargins(20, 16, 20, 16)
    h.setSpacing(14)
    
    ico = QLabel(icon)
    ico.setStyleSheet(f"font-size: 32px; background: transparent; border: none;")
    h.addWidget(ico)
    
    v = QVBoxLayout()
    v.setSpacing(2)
    val_lbl = QLabel(str(value))
    val_lbl.setStyleSheet(f"""
        font-size: 28px; 
        font-weight: 900; 
        color: {color}; 
        background: transparent; 
        border: none;
        font-family: 'Segoe UI', 'Arial', monospace;
    """)
    sub_lbl = QLabel(label.upper())
    sub_lbl.setStyleSheet(f"""
        font-size: 9px; 
        font-weight: 800; 
        color: {TEXT_SEC}; 
        letter-spacing: 2px; 
        background: transparent; 
        border: none;
    """)
    v.addWidget(val_lbl)
    v.addWidget(sub_lbl)
    h.addLayout(v)
    h.addStretch()
    card.setLayout(h)
    return card

def section_card():
    f = QFrame()
    f.setStyleSheet(f"""
        QFrame {{ 
            background-color: {CREAM}; 
            border: 1px solid {BORDER}; 
            border-radius: 12px;
        }}
    """)
    return f

def make_table():
    t = QTableWidget()
    t.setAlternatingRowColors(True)
    t.setEditTriggers(QTableWidget.EditTrigger.NoEditTriggers)
    t.setShowGrid(False)
    t.verticalHeader().setVisible(False)
    t.horizontalHeader().setHighlightSections(False)
    t.setFrameShape(QFrame.Shape.NoFrame)
    t.setStyleSheet(TABLE_STYLE)
    t.verticalHeader().setDefaultSectionSize(55)
    t.horizontalHeader().setStretchLastSection(True)
    t.setItemDelegate(CenterDelegate())
    t.horizontalHeader().setDefaultAlignment(Qt.AlignmentFlag.AlignCenter)
    t.setSelectionBehavior(QTableWidget.SelectionBehavior.SelectRows)
    t.setSelectionMode(QTableWidget.SelectionMode.SingleSelection)
    t.setSortingEnabled(True) 
    
    font = QFont("MuseoModerno", 10)
    t.setFont(font)
    
    return t

# Dialog for managing Crop Types
class CropTypeManagementDialog(QDialog):
    def __init__(self, db, parent=None, type_id=None, type_name=None):
        super().__init__(parent)
        self.db = db
        self.type_id = type_id
        self.setWindowTitle("Manage Crop Type" if not type_id else "Edit Crop Type")
        self.setModal(True)
        self.setFixedSize(400, 200)
        
        self.setStyleSheet(f"""
            QDialog {{
                background-color: {BG_PANEL};
            }}
            QLabel {{
                color: {TEXT_PRI};
                font-size: 13px;
                font-weight: 500;
            }}
        """)
        
        layout = QVBoxLayout()
        layout.setSpacing(20)
        layout.setContentsMargins(30, 30, 30, 30)
        
        # Crop Type name input
        name_layout = QVBoxLayout()
        name_label = QLabel("🌾 Crop Type Name:")
        name_label.setStyleSheet(f"color: {ACCENT2}; font-weight: bold;")
        self.type_name_input = QLineEdit()
        self.type_name_input.setPlaceholderText("Enter crop type (e.g., Grain, Vegetable, Fruit)...")
        self.type_name_input.setStyleSheet(INPUT_STYLE)
        if type_name:
            self.type_name_input.setText(type_name)
        name_layout.addWidget(name_label)
        name_layout.addWidget(self.type_name_input)
        layout.addLayout(name_layout)
        
        # Buttons
        button_layout = QHBoxLayout()
        button_layout.setSpacing(10)
        
        self.save_btn = QPushButton("💾 Save")
        self.save_btn.setStyleSheet(BTN_PRIMARY)
        self.save_btn.clicked.connect(self.save_type)
        
        self.cancel_btn = QPushButton("❌ Cancel")
        self.cancel_btn.setStyleSheet(BTN_GHOST)
        self.cancel_btn.clicked.connect(self.reject)
        
        button_layout.addWidget(self.save_btn)
        button_layout.addWidget(self.cancel_btn)
        layout.addLayout(button_layout)
        
        self.setLayout(layout)
    
    def save_type(self):
        type_name = self.type_name_input.text().strip()
        if not type_name:
            QMessageBox.warning(self, "Warning", "Please enter a crop type name!")
            return
        
        try:
            if self.type_id:  # Update existing crop type
                self.db.update_crop_type(self.type_id, type_name)
                QMessageBox.information(self, "Success", f"✅ Crop Type '{type_name}' updated successfully!")
            else:  # Add new crop type
                self.db.add_crop_type(type_name)
                QMessageBox.information(self, "Success", f"✅ Crop Type '{type_name}' added successfully!")
            self.accept()
        except Exception as e:
            QMessageBox.warning(self, "Error", f"❌ Failed to save crop type: {str(e)}")

# Dialog for managing Crops (with foreign key to Crop Types)
class CropManagementDialog(QDialog):
    def __init__(self, db, parent=None, crop_id=None, crop_name=None, crop_type_id=None):
        super().__init__(parent)
        self.db = db
        self.crop_id = crop_id
        self.setWindowTitle("Manage Crop" if not crop_id else "Edit Crop")
        self.setModal(True)
        self.setFixedSize(450, 250)
        
        self.setStyleSheet(f"""
            QDialog {{
                background-color: {BG_PANEL};
            }}
            QLabel {{
                color: {TEXT_PRI};
                font-size: 13px;
                font-weight: 500;
            }}
        """)
        
        layout = QVBoxLayout()
        layout.setSpacing(20)
        layout.setContentsMargins(30, 30, 30, 30)
        
        # Crop Type selection
        type_layout = QVBoxLayout()
        type_label = QLabel("📂 Crop Type:")
        type_label.setStyleSheet(f"color: {ACCENT2}; font-weight: bold;")
        self.crop_type_combo = QComboBox()
        self.crop_type_combo.setStyleSheet(COMBO_STYLE)
        self.load_crop_types()
        if crop_type_id:
            index = self.crop_type_combo.findData(crop_type_id)
            if index >= 0:
                self.crop_type_combo.setCurrentIndex(index)
        type_layout.addWidget(type_label)
        type_layout.addWidget(self.crop_type_combo)
        layout.addLayout(type_layout)
        
        # Crop name input
        name_layout = QVBoxLayout()
        name_label = QLabel("🌾 Crop Name:")
        name_label.setStyleSheet(f"color: {ACCENT2}; font-weight: bold;")
        self.crop_name_input = QLineEdit()
        self.crop_name_input.setPlaceholderText("Enter crop name...")
        self.crop_name_input.setStyleSheet(INPUT_STYLE)
        if crop_name:
            self.crop_name_input.setText(crop_name)
        name_layout.addWidget(name_label)
        name_layout.addWidget(self.crop_name_input)
        layout.addLayout(name_layout)
        
        # Buttons
        button_layout = QHBoxLayout()
        button_layout.setSpacing(10)
        
        self.save_btn = QPushButton("💾 Save")
        self.save_btn.setStyleSheet(BTN_PRIMARY)
        self.save_btn.clicked.connect(self.save_crop)
        
        self.cancel_btn = QPushButton("❌ Cancel")
        self.cancel_btn.setStyleSheet(BTN_GHOST)
        self.cancel_btn.clicked.connect(self.reject)
        
        button_layout.addWidget(self.save_btn)
        button_layout.addWidget(self.cancel_btn)
        layout.addLayout(button_layout)
        
        self.setLayout(layout)
    
    def load_crop_types(self):
        self.crop_type_combo.clear()
        crop_types = self.db.get_crop_types()
        for crop_type in crop_types:
            self.crop_type_combo.addItem(f"📂 {crop_type[1]}", crop_type[0])
    
    def save_crop(self):
        crop_name = self.crop_name_input.text().strip()
        crop_type_id = self.crop_type_combo.currentData()
        
        if not crop_name:
            QMessageBox.warning(self, "Warning", "Please enter a crop name!")
            return
        
        if not crop_type_id:
            QMessageBox.warning(self, "Warning", "Please select a crop type!")
            return
        
        try:
            if self.crop_id:  # Update existing crop
                self.db.update_crop(self.crop_id, crop_name, crop_type_id)
                QMessageBox.information(self, "Success", f"✅ Crop '{crop_name}' updated successfully!")
            else:  # Add new crop
                self.db.add_crop(crop_name, crop_type_id)
                QMessageBox.information(self, "Success", f"✅ Crop '{crop_name}' added successfully!")
            self.accept()
        except Exception as e:
            QMessageBox.warning(self, "Error", f"❌ Failed to save crop: {str(e)}")

