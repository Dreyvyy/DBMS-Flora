            w = QWidget()
            w.setStyleSheet("background: transparent;")
            wl = QVBoxLayout()
            wl.setContentsMargins(0, 12, 0, 0)
            wl.addWidget(card)
            w.setLayout(wl)
            return w
        
        basic_data = self.db.crop_report()
        self.tabs.addTab(wrap(build_report_table(
            ["🌾 CROP", "📊 TIMES PLANTED"],
            basic_data
        ), "Crop Planting Frequency"), "Basic Report")
        
