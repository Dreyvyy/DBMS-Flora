        delete_crop_btn = QPushButton("🗑️ Delete Selected")
        delete_crop_btn.setStyleSheet(BTN_DANGER)
        delete_crop_btn.clicked.connect(self.delete_crop)
        
        btn_layout.addWidget(edit_crop_btn)
        btn_layout.addWidget(delete_crop_btn)
        btn_layout.addStretch()
        
        layout.addLayout(btn_layout)
        self.crops_tab.setLayout(layout)
        self.load_crops()
    
    def load_crop_types(self):
        crop_types = self.db.get_crop_types()
        self.types_table.setRowCount(len(crop_types))
        for row, crop_type in enumerate(crop_types):
            self.types_table.setItem(row, 0, QTableWidgetItem(str(crop_type[0])))
            self.types_table.setItem(row, 1, QTableWidgetItem(crop_type[1]))
        self.types_table.resizeColumnsToContents()
    
    def load_crops(self):
        crops = self.db.get_crops_with_types()
        self.crops_table.setRowCount(len(crops))
        for row, crop in enumerate(crops):
            self.crops_table.setItem(row, 0, QTableWidgetItem(str(crop[0])))
            self.crops_table.setItem(row, 1, QTableWidgetItem(crop[1]))
            self.crops_table.setItem(row, 2, QTableWidgetItem(crop[2]))
        self.crops_table.resizeColumnsToContents()
    
    def add_crop_type(self):
        dialog = CropTypeManagementDialog(self.db, self)
        if dialog.exec():
            self.load_crop_types()
    
    def edit_crop_type(self):
        current_row = self.types_table.currentRow()
        if current_row >= 0:
            type_id = int(self.types_table.item(current_row, 0).text())
            type_name = self.types_table.item(current_row, 1).text()
            dialog = CropTypeManagementDialog(self.db, self, type_id, type_name)
            if dialog.exec():
                self.load_crop_types()
                self.load_crops()  # Refresh crops as type names may have changed
        else:
            QMessageBox.warning(self, "Warning", "Please select a crop type to edit!")
    
    def delete_crop_type(self):
        current_row = self.types_table.currentRow()
        if current_row >= 0:
            type_id = int(self.types_table.item(current_row, 0).text())
            type_name = self.types_table.item(current_row, 1).text()
            
            # Check if crop type is being used by any crops
            crops_using_type = self.db.get_crops_by_type(type_id)
            
            if crops_using_type:
                crop_names = ", ".join([crop[1] for crop in crops_using_type])
                QMessageBox.warning(self, "Warning", 
                                   f"Cannot delete crop type '{type_name}' because it is being used by these crops:\n{crop_names}\n\n"
                                   "Please delete or reassign these crops first.")
                return
            
            reply = QMessageBox.question(self, 'Confirm Delete',
                                        f'Are you sure you want to delete crop type "{type_name}"?',
                                        QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)
            if reply == QMessageBox.StandardButton.Yes:
                try:
                    self.db.delete_crop_type(type_id)
                    QMessageBox.information(self, "Success", f"✅ Crop Type '{type_name}' deleted successfully!")
                    self.load_crop_types()
                except Exception as e:
                    QMessageBox.warning(self, "Error", f"❌ Failed to delete crop type: {str(e)}")
        else:
            QMessageBox.warning(self, "Warning", "Please select a crop type to delete!")
    
    def add_crop(self):
        dialog = CropManagementDialog(self.db, self)
        if dialog.exec():
            self.load_crops()
    
    def edit_crop(self):
        current_row = self.crops_table.currentRow()
        if current_row >= 0:
            crop_id = int(self.crops_table.item(current_row, 0).text())
            crop_name = self.crops_table.item(current_row, 1).text()
            # Get crop_type_id from database
            crop_data = self.db.get_crop_by_id(crop_id)
            crop_type_id = crop_data[2] if crop_data else None
            dialog = CropManagementDialog(self.db, self, crop_id, crop_name, crop_type_id)
            if dialog.exec():
                self.load_crops()
        else:
            QMessageBox.warning(self, "Warning", "Please select a crop to edit!")
    
    def delete_crop(self):
        current_row = self.crops_table.currentRow()
        if current_row >= 0:
            crop_id = int(self.crops_table.item(current_row, 0).text())
            crop_name = self.crops_table.item(current_row, 1).text()
            
            # Check if crop is being used in records
            records = self.db.fetch_records("")
            crop_in_use = any(record[1] == crop_name for record in records)
            
            if crop_in_use:
                QMessageBox.warning(self, "Warning", 
                                   f"Cannot delete crop '{crop_name}' because it is being used in existing records!\n"
                                   "Please delete all records using this crop first.")
                return
            
            reply = QMessageBox.question(self, 'Confirm Delete',
                                        f'Are you sure you want to delete crop "{crop_name}"?',
                                        QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No)
            if reply == QMessageBox.StandardButton.Yes:
                try:
                    self.db.delete_crop(crop_id)
                    QMessageBox.information(self, "Success", f"✅ Crop '{crop_name}' deleted successfully!")
                    self.load_crops()
                except Exception as e:
                    QMessageBox.warning(self, "Error", f"❌ Failed to delete crop: {str(e)}")
        else:
            QMessageBox.warning(self, "Warning", "Please select a crop to delete!")

